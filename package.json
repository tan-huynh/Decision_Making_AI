{
  "name": "decision-making-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:next\"",
    "dev:next": "next dev --webpack",
    "dev:backend": "backend/.venv/bin/python backend/main.py",
    "test:backend": "PYTHONPATH=backend backend/.venv/bin/python -m unittest discover -s backend/tests",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@types/d3": "^7.4.3",
    "concurrently": "^9.2.1",
    "d3": "^7.9.0",
    "lucide-react": "^0.556.0",
    "next": "16.2.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.27",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "typescript": "^5"
  }
}
